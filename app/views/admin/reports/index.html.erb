<h3>通報一覧</h3>

<div class="mb-3">
  <%= link_to "未対応", admin_reports_path(status: "open"), class: "btn btn-outline-secondary btn-sm" %>
  <%= link_to "対応中", admin_reports_path(status: "investigating"), class: "btn btn-outline-secondary btn-sm" %>
  <%= link_to "対応済", admin_reports_path(status: "resolved"), class: "btn btn-outline-secondary btn-sm" %>
  <%= link_to "全て", admin_reports_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<table class="table">
  <thead>
    <tr>
      <th>日時</th>
      <th>理由</th>
      <th>投稿</th>
      <th>通報者</th>
      <th>状態</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @reports.each do |r| %>
      <tr>
        <td><%= r.created_at.strftime("%Y/%m/%d %H:%M") %></td>
        <td><%= r.reason %></td>
        <td><%= link_to "投稿##{r.post_id}", post_path(r.post) %></td>
        <td><%= r.reporter.name %></td>
        <td><%= r.status %></td>
        <td><%= link_to "詳細", admin_report_path(r), class: "btn btn-sm btn-primary" %></td>
      </tr>
    <% end %>
  </tbody>
</table>