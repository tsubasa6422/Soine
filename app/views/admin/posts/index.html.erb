<h1>Posts</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>User</th>
      <th>Area</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>

  <tbody>
    <% @posts.each do |p| %>
      <tr>
        <td><%= p.id %></td>
        <td><%= p.title %></td>
        <td><%= p.user&.name %></td>
        <td><%= p.area&.name %></td>
        <td><%= p.created_at.strftime("%Y-%m-%d") %></td>
        <td><%= link_to "Show", admin_post_path(p) %></td>
      </tr>
    <% end %>
  </tbody>
</table>
